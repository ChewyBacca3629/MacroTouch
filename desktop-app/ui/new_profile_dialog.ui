<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>NewProfileDialog</class>
 <widget class="QDialog" name="NewProfileDialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>380</width>
    <height>240</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Nový profil</string>
  </property>

  <layout class="QVBoxLayout">

   <!-- Nadpis -->
   <item>
    <widget class="QLabel" name="labelTitle">
     <property name="text">
      <string>Vytvoriť nový profil</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignHCenter</set>
     </property>
    </widget>
   </item>

   <!-- Formulár -->
   <item>
    <layout class="QFormLayout">

     <item row="0" column="0">
      <widget class="QLabel">
       <property name="text">
        <string>Názov profilu:</string>
       </property>
      </widget>
     </item>

     <item row="0" column="1">
      <widget class="QLineEdit" name="lineProfileName">
       <property name="placeholderText">
        <string>Napr. Main, Gaming, Spotify…</string>
       </property>
      </widget>
     </item>

     <item row="1" column="0">
      <widget class="QLabel">
       <property name="text">
        <string>Typ profilu:</string>
       </property>
      </widget>
     </item>

     <item row="1" column="1">
      <widget class="QComboBox" name="comboProfileType">
       <item>
        <property name="text">
         <string>Grid (štandardné tlačidlá)</string>
        </property>
       </item>
       <item>
        <property name="text">
         <string>System monitor (CPU/GPU/RAM…)</string>
        </property>
       </item>
       <item>
        <property name="text">
         <string>Audio mixer (hlasitosť aplikácií)</string>
        </property>
       </item>
       <item>
        <property name="text">
         <string>Media control (Spotify)</string>
        </property>
       </item>
      </widget>
     </item>

    </layout>
   </item>

   <!-- Popis -->
   <item>
    <widget class="QLabel" name="labelTypeDescription">
     <property name="text">
      <string>Vyberte typ nového profilu.</string>
     </property>
     <property name="wordWrap">
      <bool>true</bool>
     </property>
    </widget>
   </item>

   <!-- ButtonBox -->
   <item>
    <widget class="QDialogButtonBox" name="buttonBox">
     <property name="standardButtons">
      <set>QDialogButtonBox::Ok|QDialogButtonBox::Cancel</set>
     </property>
    </widget>
   </item>

  </layout>
 </widget>

